{
  "name": "usproglove-marketing-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:campaign": "tsx --env-file=.env.local scripts/seed-campaign.ts",
    "qstash:setup": "tsx --env-file=.env.local scripts/setup-qstash-schedules.ts",
    "qstash:list": "tsx --env-file=.env.local -e \"import('@upstash/qstash').then(({Client})=>new Client({token:process.env.QSTASH_TOKEN!}).schedules.list().then(l=>console.table(l.map(s=>({id:s.scheduleId,cron:s.cron,dest:s.destination})))))\""
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@auth0/nextjs-auth0": "^4.16.0",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.168",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@upstash/qstash": "^2.10.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
